# Alpaca — paper trading par défaut (https://alpaca.markets)
# Utilise https://paper-api.alpaca.markets pour le paper trading.
# Utilise https://api.alpaca.markets pour le live trading (comptes vérifiés uniquement).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Telegram — notifications de fin de run
# 1. @BotFather → /newbot → récupérer le token
# 2. Envoyer un message au bot, puis appeler
#    https://api.telegram.org/bot<TOKEN>/getUpdates pour récupérer chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnel: tag de mode, utilisé par les scripts pour log/garde-fou
TRADING_MODE=paper
