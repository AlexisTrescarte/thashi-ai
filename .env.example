# Alpaca — paper trading par défaut (https://alpaca.markets)
# Utilise https://paper-api.alpaca.markets pour le paper trading.
# Utilise https://api.alpaca.markets pour le live trading (comptes vérifiés uniquement).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Telegram — notifications de fin de run
# 1. @BotFather → /newbot → récupérer le token
# 2. Envoyer un message au bot, puis appeler
#    https://api.telegram.org/bot<TOKEN>/getUpdates pour récupérer chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnel: tag de mode, utilisé par les scripts pour log/garde-fou
TRADING_MODE=paper

# chart-img.com Pro subscription (50/day, 1/sec) — used by hf_btc agent
CHART_IMG_API_KEY=

# Bull-HF-BTC mode toggle
# 1 = TEST mode (loosened soft gates: confidence floor 40, cooldown 5min, confluence ≥3/7)
# 0 or unset = PROD mode (confidence 50, cooldown 15min, confluence ≥4/7)
# Hard guardrails (R/R 1.8, sizing 2-12%, daily cap -3%, spread 0.15%) are NEVER softened.
HF_TEST_MODE=0
